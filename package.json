{
  "name": "focusdaw-mastering-desk",
  "private": true,
  "version": "0.8.6",
  "description": "FocusDAW - Mastering Desk",
  "author": "FocusDAW",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npm run electron:dev",
    "web:dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && node scripts/run-electron.mjs\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:dir": "npm run build && electron-builder --win --dir",
    "electron:publish": "npm run build && electron-builder --win --publish always",
    "verify": "node scripts/verify-decoder.mjs"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@types/three": "^0.185.0",
    "electron-updater": "^6.3.9",
    "libflacjs": "^5.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.0",
    "electron": "42.4.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^8.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.focusdaw.masteringdesk",
    "productName": "FocusDAW - Mastering Desk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/logo-main2.png"
    ],
    "publish": {
      "provider": "github",
      "owner": "limsunglyong",
      "repo": "FocusDAW-Mastering"
    },
    "win": {
      "icon": "assets/logo-main2.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
